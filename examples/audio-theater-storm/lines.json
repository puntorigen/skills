      "index": 0,
      "speaker": "Narrator",
      "voice": "at-the-keeper-of-karsk-narrator",
      "text": "The lighthouse at Karsk had not gone dark in ninety years.",
      "emotion": "grave",
      "tags": [],
      "exaggeration": 0.525,
      "cfg_weight": 0.4,
      "file": "lines/line-000.wav",
      "start": 0.0,
